APP_MODE="demo"

# Comma-separated hostnames or full URLs allowed in `next dev` when not using localhost.
# Example: 192.168.5.9 or http://192.168.5.9:3000
DEV_ALLOWED_ORIGINS="192.168.5.9"

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_video_assistant"
REDIS_URL="redis://localhost:6379"

# Object storage — MinIO locally (docker compose) or Cloudflare R2 in production
OBJECT_STORAGE_ENDPOINT="http://127.0.0.1:9000"
OBJECT_STORAGE_BUCKET="ai-video-assistant"
OBJECT_STORAGE_ACCESS_KEY_ID="minioadmin"
OBJECT_STORAGE_SECRET_ACCESS_KEY="minioadmin"
OBJECT_STORAGE_REGION="us-east-1"
# Optional CDN/public URL prefix for browser-accessible assets
OBJECT_STORAGE_PUBLIC_URL=""

# Auth (NextAuth v5) — AUTH_SECRET is required; generate with: openssl rand -hex 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
# Resend email service (magic-link login)
RESEND_API_KEY=""
EMAIL_FROM="AI短视频助手 <noreply@resend.dev>"

# Sentry error monitoring (optional — omit SENTRY_DSN to disable)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# WeChat OAuth (optional — omit WECHAT_APP_ID to disable WeChat login)
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""

OPENAI_API_KEY=""
# OpenAI-compatible base URL (e.g. https://api.openai.com/v1 or DeepSeek/other compatible endpoint)
OPENAI_BASE_URL=""
AVATAR_PROVIDER="heygen"
AVATAR_PROVIDER_API_KEY=""
